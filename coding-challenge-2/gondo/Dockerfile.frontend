# Multi-stage: build Nx/Vite frontend, serve static assets with nginx (SPA routing).
ARG VITE_NOTIFICATION_SERVICE_URL=http://localhost:8001

# -----------------------------------------------------------------------------
# Stage 1: Build
# -----------------------------------------------------------------------------
FROM node:20-slim AS builder

ARG VITE_NOTIFICATION_SERVICE_URL
ENV VITE_NOTIFICATION_SERVICE_URL=${VITE_NOTIFICATION_SERVICE_URL}

WORKDIR /app

COPY package.json yarn.lock ./
RUN corepack enable && yarn install --frozen-lockfile

COPY . .
RUN yarn nx run frontend:build

# -----------------------------------------------------------------------------
# Stage 2: Serve with nginx
# -----------------------------------------------------------------------------
FROM nginx:alpine

RUN apk add --no-cache curl

COPY --from=builder /app/dist/apps/frontend /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
