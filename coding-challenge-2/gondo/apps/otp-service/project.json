{
  "name": "otp-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/otp-service",
  "implicitDependencies": ["py-core"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "../../.venv/bin/python3 -m uvicorn main:app --reload --port 8007",
        "cwd": "apps/otp-service",
        "env": {
          "PYTHONPATH": "../../libs/py-core",
          "DATABASE_URL": "postgresql://gondo:gondo@localhost:5432/gondo"
        }
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "../../.venv/bin/python3 -m pytest",
        "cwd": "apps/otp-service",
        "env": {
          "PYTHONPATH": "../../libs/py-core"
        }
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "../../.venv/bin/python3 -m ruff check .",
        "cwd": "apps/otp-service"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "../../.venv/bin/python3 -m ruff check . && ../../.venv/bin/python3 -c \"from main import app\"",
        "cwd": "apps/otp-service",
        "env": {
          "PYTHONPATH": "../../libs/py-core"
        }
      }
    }
  },
  "tags": ["python", "fastapi"]
}
