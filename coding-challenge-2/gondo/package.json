{
  "name": "gondo",
  "version": "0.0.1",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=20.19.0 <21.0.0",
    "yarn": ">=1.22.0"
  },
  "scripts": {
    "nx": "nx",
    "start": "LOG_LEVEL=DEBUG LOG_PAYLOADS=true ./scripts/start-all.sh",
    "stop": "./scripts/stop-all.sh",
    "docker:up": "docker-compose up --build -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:start": "docker-compose up -d postgres && echo 'Waiting for Postgres...' && sleep 2 && docker-compose exec postgres pg_isready -U gondo -d gondo",
    "db:stop": "docker-compose stop postgres",
    "db:migrate": "./scripts/db-migrate.sh",
    "db:reset": "docker-compose down -v postgres && yarn db:start && yarn db:migrate",
    "test:integration": "RUN_INTEGRATION_TESTS=1 python3 -m pytest tests/integration -v -s --log-cli-level=INFO"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nx/eslint": "^22.6.4",
    "@nx/eslint-plugin": "22.6.4",
    "@nx/js": "^22.6.4",
    "@nx/react": "^22.6.4",
    "@nx/vite": "^22.6.4",
    "@nx/vitest": "22.6.4",
    "@nx/web": "22.6.4",
    "@nx/workspace": "^22.6.4",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "~4.1.0",
    "@vitest/ui": "~4.1.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "nx": "^22.6.4",
    "prettier": "~3.6.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^8.0.0",
    "vitest": "~4.1.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.14.0"
  }
}
