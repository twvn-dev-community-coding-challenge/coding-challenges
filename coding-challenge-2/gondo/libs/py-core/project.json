{
  "name": "py-core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/py-core",
  "implicitDependencies": ["grpc-contracts"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "../../.venv/bin/python3 -m ruff check .",
        "cwd": "libs/py-core"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "../../.venv/bin/python3 -m pytest tests",
        "cwd": "libs/py-core",
        "env": {
          "PYTHONPATH": "../grpc-contracts"
        }
      }
    }
  },
  "tags": ["python", "shared"]
}
