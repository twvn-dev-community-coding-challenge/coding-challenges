# Redis connection URL (default: redis://localhost:6379/0)
REDIS_URL=redis://localhost:6379/0

# The name of the queue that the BullMQ worker should process (default: sms_queue)
QUEUE_NAME=sms_queue

# PostgreSQL database connection URL (SMS messages + status logs are stored here)
DATABASE_URL=postgres://user:password@localhost:5432/sms_otp?sslmode=disable
#
# Docker Compose `api` service overrides DATABASE_URL/REDIS_URL internally; use this when running the binary on the host.
#
# Web (Vite) in Compose: open http://localhost:5173 — proxy target is set via VITE_PROXY_API in compose (see docker-compose.yml).

# Logging: omit or "text" for human-readable; "json" for Loki / log aggregators
# LOG_FORMAT=json
#
# Registration OTP is printed to stdout after SMS succeeds (default). Set false in production:
# LOG_REGISTRATION_OTP=false

# Protect /api/sms/send, /messages, /messages/:id, /stats (Bearer or X-Internal-Key). Required for production-like setups.
SMS_INTERNAL_API_KEY=dev-local-sms-key

# Optional: require X-Callback-Secret on POST /api/sms/callback
# SMS_CALLBACK_SECRET=

# Allow x-test-sms-mode header (set true for local e2e that exercise test modes)
ALLOW_TEST_SMS_HEADERS=true
